<style>
:root{
  --gold:#f5c518;--gold2:#e8a000;--dark:#0a0a0f;--dark2:#12121c;
  --dark3:#1a1a28;--card:#1e1e2e;--border:#2a2a3e;
  --green:#00c97a;--red:#ff4560;--blue:#3b82f6;--purple:#a855f7;
  --text:#e8e8f0;--muted:#666680;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html,body{width:100%;min-height:100vh;background:var(--dark);color:var(--text);
  font-family:'Prompt',sans-serif;overflow-x:hidden;}
.screen{display:none;min-height:100vh;flex-direction:column;animation:fadeIn .3s ease;}
.screen.active{display:flex;}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;
  background:radial-gradient(ellipse at 20% 20%,#1a0a3020,transparent 60%),
             radial-gradient(ellipse at 80% 80%,#0a1a2020,transparent 60%);}
.logo{font-family:'Bebas Neue',cursive;font-size:3rem;letter-spacing:.1em;
  background:linear-gradient(135deg,var(--gold),#fff5a0,var(--gold2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  text-align:center;padding:2rem 1rem .5rem;line-height:1;position:relative;z-index:1;}
.logo-sub{text-align:center;color:var(--muted);font-size:.75rem;letter-spacing:.3em;
  text-transform:uppercase;margin-bottom:1.5rem;position:relative;z-index:1;}
.card{background:var(--card);border:1px solid var(--border);border-radius:16px;
  padding:1.25rem;position:relative;z-index:1;}
.card-title{font-size:.7rem;letter-spacing:.25em;text-transform:uppercase;color:var(--muted);margin-bottom:.75rem;}
.btn{display:block;width:100%;padding:.85rem 1.25rem;border:none;border-radius:12px;
  font-family:'Prompt',sans-serif;font-size:1rem;font-weight:700;cursor:pointer;
  transition:all .15s;text-align:center;letter-spacing:.05em;}
.btn:active{transform:scale(.97);}
.btn:disabled{opacity:.4;cursor:not-allowed;transform:none;}
.btn-gold{background:linear-gradient(135deg,var(--gold),var(--gold2));color:#000;box-shadow: 0 4px 15px rgba(245,197,24,0.3);}
.btn-outline{background:transparent;border:1.5px solid var(--border);color:var(--text);}
.btn-outline:hover{border-color:var(--gold);color:var(--gold);}
.btn-green{background:var(--green);color:#000;}
.btn-ghost{background:transparent;color:var(--muted);font-size:.8rem;padding:.5rem;}
input[type=text],input[type=number]{
  width:100%;padding:.75rem 1rem;background:var(--dark3);border:1.5px solid var(--border);
  border-radius:10px;color:var(--text);font-family:'Prompt',sans-serif;font-size:1rem;
  outline:none;transition:border .15s;}
input:focus{border-color:var(--gold);}
input::placeholder{color:var(--muted);}
.badge{display:inline-block;padding:.2rem .55rem;border-radius:6px;font-size:.68rem;font-weight:700;}
.badge-gold{background:#f5c51820;color:var(--gold);border:1px solid #f5c51840;}
.badge-green{background:#00c97a20;color:var(--green);border:1px solid #00c97a40;}
.badge-blue{background:#3b82f620;color:var(--blue);border:1px solid #3b82f640;}
.money{font-weight:900;color:var(--gold);}
.money-neg{color:var(--red)!important;font-weight:900;}
#toast{position:fixed;top:1.5rem;left:50%;transform:translateX(-50%) translateY(-130px);
  background:var(--card);border:1.5px solid var(--gold);border-radius:12px;
  padding:.7rem 1.4rem;font-size:.88rem;font-weight:600;z-index:9999;
  transition:transform .3s cubic-bezier(.34,1.56,.64,1);max-width:90vw;text-align:center;}
#toast.show{transform:translateX(-50%) translateY(0);}

/* LOBBY */
#screen-lobby{padding:0 1rem 2rem;gap:.65rem;}
.p-item{display:flex;align-items:center;gap:.7rem;background:var(--dark3);
  border:1px solid var(--border);border-radius:12px;padding:.7rem .9rem;margin-bottom:.35rem;}
.p-avatar{width:38px;height:38px;border-radius:9px;
  display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;}

/* GAME */
#screen-game{padding:0;}
.top-bar{background:var(--dark2);border-bottom:1px solid var(--border);padding:.7rem 1rem;
  display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;}
.top-bar-title{font-family:'Bebas Neue',cursive;font-size:1.4rem;color:var(--gold);}
.top-bar-r{font-size:.72rem;color:var(--muted);text-align:right;}
.top-bar-r strong{color:var(--text);display:block;font-size:.88rem;}
.money-bar{background:linear-gradient(135deg,var(--dark3),var(--card));
  border-bottom:1px solid var(--border);padding:.7rem 1rem;
  display:flex;align-items:center;justify-content:space-between;}
.money-lbl{font-size:.68rem;color:var(--muted);letter-spacing:.12em;text-transform:uppercase;}
.money-big{font-size:1.55rem;font-weight:900;color:var(--gold);}
.phase-bar{display:flex;justify-content:center;gap:.3rem;padding:.55rem 1rem;
  background:var(--dark2);border-bottom:1px solid var(--border);}
.pd{width:8px;height:8px;border-radius:50%;background:var(--border);transition:all .3s;}
.pd.active{background:var(--gold);width:24px;border-radius:4px;}
.pd.done{background:var(--green);}
.gcontent{padding:.85rem;display:flex;flex-direction:column;gap:.85rem;padding-bottom:6rem;}

/* SECTION EXPAND */
.sec-hdr{display:flex;align-items:center;justify-content:space-between;
  background:var(--dark3);border:2px solid var(--border);border-radius:12px;
  padding:.7rem .9rem;cursor:pointer;transition:all .2s;user-select:none;}
.sec-hdr.open{border-color:var(--gold);background:#f5c51808;border-radius:12px 12px 0 0;}
.sec-hdr-left{font-weight:700;font-size:.93rem;display:flex;align-items:center;gap:.4rem;flex-wrap:wrap;}
.sec-hdr-right{display:flex;align-items:center;gap:.4rem;font-size:.72rem;color:var(--muted);flex-shrink:0;}
.chevron{transition:transform .2s;font-size:.9rem;}
.sec-hdr.open .chevron{transform:rotate(180deg);}
.sec-body{display:none;background:var(--card);border:1px solid var(--gold);border-top:none;
  border-radius:0 0 12px 12px;padding:.9rem .85rem;}
.sec-body.open{display:block;}

/* HORSE */
.horse-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:.45rem;margin:.45rem 0;}
.hbtn{aspect-ratio:1;border-radius:10px;background:var(--dark3);border:2px solid var(--border);
  display:flex;align-items:center;justify-content:center;font-size:1.45rem;font-weight:900;
  cursor:pointer;transition:all .18s;}
.hbtn:active{transform:scale(.92);}
.hbtn.sel{border-color:var(--gold);background:#f5c51820;box-shadow:0 0 0 3px #f5c51830;}

/* HOUSE */
.htype-title{font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;
  color:var(--muted);margin:.55rem 0 .3rem;}
.house-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.38rem;}
.hsbtn{padding:.5rem .2rem;border-radius:8px;background:var(--dark3);border:2px solid var(--border);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  cursor:pointer;transition:all .18s;min-height:56px;}
.hsbtn.sel{border-color:var(--gold);background:#f5c51815;}
.hsbtn.own-me{border-color:var(--green);background:#00c97a10;}
.hsbtn.own-other{border-color:var(--blue);background:#3b82f610;}
.hs-lbl{font-size:.82rem;font-weight:900;}
.hs-own{font-size:.5rem;margin-top:2px;text-align:center;}

/* QUICK BTNS */
.qrow{display:flex;gap:.32rem;flex-wrap:wrap;margin:.4rem 0;}
.qbtn{padding:.28rem .52rem;background:var(--dark3);border:1px solid var(--border);
  border-radius:6px;font-size:.7rem;cursor:pointer;font-family:'Prompt',sans-serif;
  font-weight:600;transition:all .12s;color:var(--text);}
.qbtn:active{background:var(--gold);color:#000;border-color:var(--gold);}
.irow{display:flex;gap:.4rem;align-items:center;margin-top:.4rem;}
.irow input{flex:1;}

/* WAITING */
.wait-item{display:flex;align-items:center;justify-content:space-between;
  background:var(--dark3);border:1px solid var(--border);border-radius:9px;
  padding:.5rem .75rem;font-size:.8rem;margin-bottom:.3rem;}

/* LB */
.lb-row{display:flex;align-items:center;gap:.6rem;
  padding:.5rem .65rem;border-radius:9px;background:var(--dark3);margin-bottom:.3rem;}
.lb-rank{font-family:'Bebas Neue',cursive;font-size:1.2rem;width:25px;text-align:center;}
.lb-rank.r1{color:var(--gold);}
.lb-rank.r2{color:#aaa;}
.lb-rank.r3{color:#cd7f32;}
.lb-name{font-weight:700;flex:1;font-size:.85rem;}
.lb-money{font-weight:900;font-size:.9rem;color:var(--gold);}

/* RACE */
.race-track{background:var(--dark3);border-radius:10px;padding:.65rem;margin:.45rem 0;}
.t-lane{display:flex;align-items:center;gap:.35rem;margin-bottom:.25rem;height:24px;}
.t-num{width:16px;font-size:.62rem;color:var(--muted);font-weight:700;flex-shrink:0;}
.t-bar{flex:1;background:var(--dark);border-radius:3px;height:10px;position:relative;overflow:hidden;}
.t-fill{height:100%;border-radius:3px;width:0%;
  transition:width 1.3s cubic-bezier(.4,0,.2,1);
  background:linear-gradient(90deg,var(--gold),var(--gold2));}
.t-fill.win{background:linear-gradient(90deg,var(--green),#00ff9a)!important;}
.t-rnk{font-size:.58rem;color:var(--muted);flex-shrink:0;width:16px;text-align:right;}

/* RESULT */
.r-card{background:var(--card);border:1px solid var(--border);border-radius:14px;
  padding:1rem;margin-bottom:.6rem;}
.r-title{font-family:'Bebas Neue',cursive;font-size:1.35rem;color:var(--gold);margin-bottom:.55rem;}
.r-row{display:flex;justify-content:space-between;align-items:center;
  padding:.32rem 0;border-bottom:1px solid #ffffff07;font-size:.8rem;}
.r-row:last-child{border-bottom:none;}

.done-banner{background:linear-gradient(135deg,#00c97a18,var(--card));
  border:1px solid var(--green);border-radius:12px;padding:.75rem 1rem;
  text-align:center;font-weight:700;color:var(--green);font-size:.88rem;}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.45;}}
.pulse{animation:pulse 1.4s ease infinite;}

/* MATH EVENT */
.ev-btn { padding: 1.2rem; background: var(--dark3); border: 2px solid var(--border); border-radius: 12px; font-size: 1.5rem; font-weight: 700; cursor: pointer; text-align: center; transition: all .2s; }
.ev-btn:active { transform: scale(0.95); }
.ev-btn.selected { background: var(--gold); color: #000; border-color: var(--gold); }
#ev-timer { font-family:'Bebas Neue',cursive; font-size: 2rem; color: var(--red); }

@keyframes confetti-fall{
  0%{transform:translateY(-20px) rotate(0deg);opacity:1;}
  100%{transform:translateY(100vh) rotate(720deg);opacity:0;}}
.confetti-piece{position:fixed;top:0;border-radius:2px;
  animation:confetti-fall linear forwards;pointer-events:none;z-index:1000;}

/* avatar colors */
.c0{background:#f5c51830;color:var(--gold);}  .c1{background:#3b82f630;color:var(--blue);}
.c2{background:#00c97a30;color:var(--green);}  .c3{background:#ff456030;color:var(--red);}
.c4{background:#a855f730;color:var(--purple);}  .c5{background:#f9731630;color:#f97316;}
.c6{background:#06b6d430;color:#06b6d4;}  .c7{background:#ec489930;color:#ec4899;}
.c8{background:#84cc1630;color:#84cc16;}  .c9{background:#f4354230;color:#f43542;}
.c10{background:#8b5cf630;color:#8b5cf6;}  .c11{background:#14b8a630;color:#14b8a6;}

::-webkit-scrollbar{width:3px;}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px;}
</style>
</head>
<body>
<div id="toast"></div>

<div id="screen-home" class="screen active">
  <div class="logo" style="margin-bottom:-10px;">GAMBLAH</div>
  <div class="logo-sub">👑 Emperor Edition</div>
  <div style="padding:0 1.2rem 2rem;display:flex;flex-direction:column;gap:.7rem;flex:1;justify-content:center;">
    <div class="card" style="text-align:center;padding:1.3rem;">
      <div style="font-size:2.4rem;margin-bottom:.35rem;">🎰</div>
      <div style="font-weight:700;font-size:1.05rem;margin-bottom:.2rem;">ยินดีต้อนรับสู่ Gamblah!</div>
      <div style="color:var(--muted);font-size:.8rem;">เล่นกับเพื่อนแบบ Online ได้เลย</div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:.6rem;">
      <button class="btn btn-gold" onclick="showScreen('screen-create')">🏠 สร้างห้อง</button>
      <button class="btn btn-outline" onclick="showScreen('screen-join')">🔑 เข้าร่วม</button>
    </div>
    <div class="card" style="padding:.85rem;">
      <div class="card-title">ฟีเจอร์ใหม่</div>
      <div style="font-size:.78rem;color:var(--text);line-height:1.9;">
        ✅ ประมูลพื้นที่ได้สูงสุด <strong>3 แห่ง</strong>/ตา<br>
        ✅ ชิงตำแหน่ง <strong>จักรพรรดิ</strong> (สุ่มรับ 3 บ้านฟรี! คนสุดท้ายรับ 30k)<br>
        ✅ <strong>Event ชิงเงิน</strong> ประลองคณิตศาสตร์ ท้ายตา 2 และ 4
      </div>
    </div>
    <div id="fb-status" class="card" style="padding:.65rem;text-align:center;font-size:.75rem;color:var(--muted);">
      ⏳ กำลังเชื่อมต่อ Firebase...
    </div>
  </div>
</div>

<div id="screen-create" class="screen">
  <div class="logo" style="font-size:2rem;padding-top:1.5rem;">สร้างห้อง</div>
  <div style="padding:0 1.2rem 2rem;display:flex;flex-direction:column;gap:.7rem;flex:1;">
    <div class="card">
      <div class="card-title">ชื่อของคุณ</div>
      <input type="text" id="create-name" placeholder="ชื่อผู้เล่น..." maxlength="12">
    </div>
    <div class="card">
      <div class="card-title">รหัสห้อง</div>
      <div style="display:flex;gap:.45rem;align-items:center;">
        <input type="text" id="room-code-display" readonly
          style="font-family:'Bebas Neue',cursive;font-size:1.5rem;letter-spacing:.25em;color:var(--gold);flex:1;">
        <button class="btn btn-outline" onclick="generateRoomCode()"
          style="width:auto;padding:.72rem;border-radius:9px;font-size:.9rem;">🔄</button>
      </div>
    </div>
    <button class="btn btn-gold" id="create-btn" onclick="createRoom()">สร้างห้อง 🎲</button>
    <button class="btn btn-ghost" onclick="showScreen('screen-home')">← กลับ</button>
  </div>
</div>

<div id="screen-join" class="screen">
  <div class="logo" style="font-size:2rem;padding-top:1.5rem;">เข้าร่วม</div>
  <div style="padding:0 1.2rem 2rem;display:flex;flex-direction:column;gap:.7rem;flex:1;">
    <div class="card">
      <div class="card-title">ชื่อของคุณ</div>
      <input type="text" id="join-name" placeholder="ชื่อผู้เล่น..." maxlength="12">
    </div>
    <div class="card">
      <div class="card-title">รหัสห้อง (4 ตัว)</div>
      <input type="text" id="join-code" placeholder="เช่น AB12" maxlength="4"
        style="font-family:'Bebas Neue',cursive;font-size:1.5rem;letter-spacing:.25em;text-transform:uppercase;"
        oninput="this.value=this.value.toUpperCase()">
    </div>
    <button class="btn btn-gold" id="join-btn" onclick="joinRoom()">เข้าร่วม 🚀</button>
    <button class="btn btn-ghost" onclick="showScreen('screen-home')">← กลับ</button>
  </div>
</div>

<div id="screen-lobby" class="screen">
  <div class="logo" style="font-size:2rem;padding-top:1.5rem;">ห้องรอ</div>
  <div style="text-align:center;position:relative;z-index:1;margin-bottom:.4rem;">
    <div style="font-size:.75rem;color:var(--muted);">รหัสห้อง</div>
    <div id="lobby-code" style="font-family:'Bebas Neue',cursive;font-size:2.5rem;letter-spacing:.35em;color:var(--gold);"></div>
    <button class="btn-ghost btn" onclick="copyCode()" style="width:auto;display:inline-block;font-size:.7rem;">📋 คัดลอก</button>
  </div>
  <div style="padding:0 1rem;flex:1;display:flex;flex-direction:column;gap:.6rem;position:relative;z-index:1;">
    <div class="card">
      <div class="card-title" id="lobby-count">ผู้เล่น (0/12)</div>
      <div id="lobby-list"></div>
    </div>
    <button id="ready-btn" class="btn btn-outline" onclick="toggleReady()">✋ กด Ready</button>
    <div id="start-wrap" style="display:none;">
      <button class="btn btn-gold" onclick="startGame()">🚀 เริ่มเกม!</button>
    </div>
    <div class="card" style="font-size:.75rem;color:var(--muted);padding:.75rem 1rem;">
      ⏳ รอทุกคนกด Ready ก่อน — Host จึงจะเริ่มได้
    </div>
  </div>
</div>

<div id="screen-game" class="screen">
  <div class="top-bar">
    <div class="top-bar-title">GAMBLAH</div>
    <div class="top-bar-r"><span id="hud-round">ตา 1/5</span><strong id="hud-phase">เลือกการกระทำ</strong></div>
  </div>
  <div class="phase-bar">
    <div class="pd active" id="pd1"></div><div class="pd" id="pd2"></div>
    <div class="pd" id="pd3"></div><div class="pd" id="pd4"></div><div class="pd" id="pd5"></div>
  </div>
  <div class="money-bar">
    <div><div class="money-lbl">เงินของคุณ</div><div class="money-big" id="my-money">฿20,000</div></div>
    <div style="text-align:right;"><div class="money-lbl">ผู้เล่น</div><div style="font-weight:700;" id="my-name-hud">-</div></div>
  </div>
  <div class="gcontent" id="gcontent"></div>
</div>

<div id="screen-event" class="screen">
  <div class="logo" style="font-size:2.3rem;padding-top:2rem;">🔥 EVENT ชิงเงิน!</div>
  <div style="text-align:center;color:var(--gold);font-size:.85rem;padding:0 1rem;">
    คิดเลขไว รับโบนัสสุดคุ้ม!<br>
    🥇 ที่ 1: 15,000฿ | 🥈 ที่ 2: 8,000฿ | 🥉 ที่ 3: 5,000฿
  </div>
  <div style="text-align:center;margin-top:1rem;">เวลาเหลือ: <span id="ev-timer">15</span></div>
  <div class="card" style="margin:1rem;text-align:center;border-color:var(--gold);background:var(--dark2);">
    <div style="font-size:3.5rem;font-weight:900;letter-spacing:2px;margin:1.5rem 0;color:var(--text);" id="ev-q"></div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:.8rem;" id="ev-choices"></div>
  </div>
</div>

<div id="screen-event-result" class="screen">
   <div class="logo" style="font-size:2.5rem;padding-top:2.5rem;">🎉 สรุปผล EVENT</div>
   <div id="ev-res-content" style="padding:1.5rem;display:flex;flex-direction:column;gap:.7rem;flex:1;"></div>
</div>

<div id="screen-result" class="screen">
  <div class="logo" style="font-size:2rem;padding-top:1.5rem;" id="result-heading">ผลตาที่ 1</div>
  <div style="padding:0 1rem 2rem;flex:1;display:flex;flex-direction:column;gap:.6rem;position:relative;z-index:1;" id="result-content"></div>
</div>

<div id="screen-final" class="screen">
  <div style="padding:1.8rem 1rem .8rem;text-align:center;position:relative;z-index:1;">
    <div style="font-size:2.8rem;">🏆</div>
    <div class="logo" style="font-size:2.5rem;padding:.2rem 0;">จบเกม!</div>
    <div style="color:var(--muted);font-size:.83rem;" id="winner-sub">ผู้ชนะคือ...</div>
  </div>
  <div style="padding:0 1rem 2rem;flex:1;display:flex;flex-direction:column;gap:.6rem;position:relative;z-index:1;" id="final-content"></div>
</div>

<script>
// ══════════════════════════════════════════════════════
//   GAMBLAH  —  Firebase Realtime Database Multiplayer
// ══════════════════════════════════════════════════════

const HORSE_REWARD_PCT=[400,250,200,150,150,100,75,75,75,75,50,50];
const HOUSES={
  EMP:{slots:['จักรพรรดิ'],roi:0,color:'#ff1493'}, // ตำแหน่งพิเศษ
  A:{slots:['A1','A2','A3','A4','A5'],roi:1.8,color:'#f5c518'},
  B:{slots:['B1','B2','B3','B4','B5','B6'],roi:1.6,color:'#3b82f6'},
  C:{slots:['C1','C2','C3','C4','C5','C6'],roi:1.4,color:'#a855f7'},
};
const HOUSE_END_BONUS=10000, TOTAL_ROUNDS=5, START_MONEY=20000;
const AVATARS=['🦁','🐯','🦊','🐺','🦅','🐉','🦋','🐬','🦄','🐙','🦜','🐸'];

let myId='',myName='',roomCode='',isHost=false;
let _unsub=null, _fbReady=false;
let evInterval=null;

// current round selections
let sel={horse:null,horseAmt:0,houseBids:[],houseTemp:null};
let _cachedState=null;
let _resolving = false;
let _currentPhase = '';

// ── Firebase wrappers ──
const fb=()=>window._fb;
const rref=(p='')=>fb().ref(fb().db,'rooms/'+roomCode+(p?'/'+p:''));
async function fbGet(p=''){const s=await fb().get(rref(p));return s.exists()?s.val():null;}
async function fbSet(p,v){await fb().set(rref(p),v);}
async function fbUpd(u){await fb().update(rref(),u);}
function fbOn(p,cb){const r=rref(p);fb().onValue(r,s=>cb(s.exists()?s.val():null));return()=>fb().off(r);}

// ── Helpers ──
const genId=()=>Math.random().toString(36).slice(2,9);
function genCode(){const c='ABCDEFGHJKLMNPQRSTUVWXYZ23456789';return[0,0,0,0].map(()=>c[Math.floor(Math.random()*c.length)]).join('');}
function fmt(n){if(n==null)return'฿0';const s=n<0?'-':'';return s+'฿'+Math.abs(Math.round(n)).toLocaleString();}
function showScreen(id){document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));document.getElementById(id).classList.add('active');window.scrollTo(0,0);}
let _tt=null;
function toast(m,d=2700){const e=document.getElementById('toast');e.innerHTML=m;e.classList.add('show');clearTimeout(_tt);_tt=setTimeout(()=>e.classList.remove('show'),d);}
function generateRoomCode(){roomCode=genCode();document.getElementById('room-code-display').value=roomCode;}
function copyCode(){navigator.clipboard.writeText(roomCode).then(()=>toast('📋 คัดลอกแล้ว!')).catch(()=>toast('รหัส: '+roomCode));}
function stopListen(){if(_unsub){_unsub();_unsub=null;} _currentPhase='';}
function orderedPlayers(state){
  if(!state?.players)return[];
  const o=state.playerOrder||Object.keys(state.players);
  return o.map(id=>state.players[id]).filter(Boolean);
}

document.addEventListener('firebase-ready',()=>{
  _fbReady=true;
  const el=document.getElementById('fb-status');
  el.innerHTML='✅ เชื่อมต่อ Firebase สำเร็จ — พร้อมเล่น!';
  el.style.color='var(--green)';
});

// ── CREATE & JOIN ROOM ──
async function createRoom(){
  if(!_fbReady){toast('⏳ Firebase ยังไม่พร้อม');return;}
  const name=document.getElementById('create-name').value.trim();
  if(!name){toast('⚠️ กรุณาใส่ชื่อ');return;}
  if(!roomCode){toast('⚠️ กรุณาสร้างรหัสห้อง');return;}
  const btn=document.getElementById('create-btn');
  btn.disabled=true;btn.textContent='⏳ กำลังสร้าง...';
  const existing=await fbGet();
  if(existing){toast('❌ รหัสนี้มีอยู่แล้ว กด 🔄 สร้างใหม่');btn.disabled=false;btn.textContent='สร้างห้อง 🎲';return;}
  myId=genId();myName=name;isHost=true;
  const p={id:myId,name,avatar:AVATARS[0],colorIdx:0,money:START_MONEY,ready:false,isHost:true,horse:null,horseAmt:0,houseBids:[],submitted:false};
  await fbSet('',{phase:'lobby',round:0,players:{[myId]:p},playerOrder:[myId],houses:{},roundResults:[],ts:Date.now()});
  btn.disabled=false;btn.textContent='สร้างห้อง 🎲';
  enterLobby();
}

async function joinRoom(){
  if(!_fbReady){toast('⏳ Firebase ยังไม่พร้อม');return;}
  const name=document.getElementById('join-name').value.trim();
  const code=document.getElementById('join-code').value.trim().toUpperCase();
  if(!name){toast('⚠️ กรุณาใส่ชื่อ');return;}
  if(code.length!==4){toast('⚠️ รหัสต้อง 4 ตัว');return;}
  const btn=document.getElementById('join-btn');
  btn.disabled=true;btn.textContent='⏳ กำลังเข้าร่วม...';
  roomCode=code;
  const state=await fbGet();
  if(!state){toast('❌ ไม่พบห้อง กรุณาตรวจสอบรหัส');btn.disabled=false;btn.textContent='เข้าร่วม 🚀';return;}
  if(state.phase!=='lobby'){toast('❌ เกมเริ่มแล้ว ไม่สามารถเข้าได้');btn.disabled=false;btn.textContent='เข้าร่วม 🚀';return;}
  const pc=Object.keys(state.players||{}).length;
  if(pc>=12){toast('❌ ห้องเต็มแล้ว');btn.disabled=false;btn.textContent='เข้าร่วม 🚀';return;}
  if(Object.values(state.players||{}).some(p=>p.name.toLowerCase()===name.toLowerCase())){toast('⚠️ ชื่อนี้ถูกใช้แล้ว');btn.disabled=false;btn.textContent='เข้าร่วม 🚀';return;}
  myId=genId();myName=name;isHost=false;
  const idx=pc%AVATARS.length;
  const p={id:myId,name,avatar:AVATARS[idx],colorIdx:idx,money:START_MONEY,ready:false,isHost:false,horse:null,horseAmt:0,houseBids:[],submitted:false};
  const u={[`players/${myId}`]:p,playerOrder:[...(state.playerOrder||[]),myId]};
  await fb().update(rref(),u);
  btn.disabled=false;btn.textContent='เข้าร่วม 🚀';
  enterLobby();
}

// ── LOBBY ──
function enterLobby(){
  document.getElementById('lobby-code').textContent=roomCode;
  showScreen('screen-lobby');
  stopListen();
  _unsub=fbOn('',onGameGlobal);
}

async function toggleReady(){
  const state=await fbGet();if(!state)return;
  const me=state.players?.[myId];if(!me)return;
  await fbSet(`players/${myId}/ready`,!me.ready);
}
async function startGame(){
  const state=await fbGet();if(!state)return;
  const ps=orderedPlayers(state);
  if(!ps.every(p=>p.ready)){toast('⚠️ ทุกคนต้อง Ready ก่อน!');return;}
  if(ps.length<2){toast('⚠️ ต้องมีผู้เล่นอย่างน้อย 2 คน');return;}
  const u={phase:'playing',round:1};
  ps.forEach(p=>{
    u[`players/${p.id}/submitted`]=false;
    u[`players/${p.id}/horse`]=null;u[`players/${p.id}/horseAmt`]=0;
    u[`players/${p.id}/houseBids`]=null;
  });
  await fb().update(rref(),u);
}

// ── CORE GAME LOOP CONTROLLER ──
let _prevRound=-1;
function onGameGlobal(state){
  if(!state)return;
  _cachedState=state;

  if (state.phase === 'lobby') {
    if (_currentPhase !== 'lobby') {
       _currentPhase = 'lobby';
       showScreen('screen-lobby');
    }
    const ps=orderedPlayers(state);
    document.getElementById('lobby-count').textContent=`ผู้เล่น (${ps.length}/12)`;
    document.getElementById('lobby-list').innerHTML=ps.map(p=>`
      <div class="p-item">
        <div class="p-avatar c${p.colorIdx}">${p.avatar}</div>
        <div>
          <div style="font-weight:700;font-size:.88rem;">${p.name}
            ${p.isHost?'<span class="badge badge-gold" style="margin-left:.3rem">Host</span>':''}</div>
          <div style="font-size:.68rem;color:var(--muted)">${fmt(p.money)}</div>
        </div>
        <div style="margin-left:auto;">${p.ready?'<span class="badge badge-green">✓ Ready</span>':'<span style="font-size:.7rem;color:var(--muted);">รอ...</span>'}</div>
      </div>`).join('');
    const me=state.players?.[myId];
    const rb=document.getElementById('ready-btn');
    if(me?.ready){rb.className='btn btn-green';rb.textContent='✅ Ready แล้ว!';}
    else{rb.className='btn btn-outline';rb.textContent='✋ กด Ready';}
    const amIHost = me?.isHost || isHost;
    const allR=ps.length>=2&&ps.every(p=>p.ready);
    document.getElementById('start-wrap').style.display=(amIHost&&allR)?'block':'none';
    return;
  }

  updateHUD(state);

  if (state.phase === 'ended') {
      if (_currentPhase !== 'ended') {
          _currentPhase = 'ended';
          showFinalScreen(state);
      }
      return;
  }

  if (state.phase === 'result') {
      if (_currentPhase !== 'result') {
          _currentPhase = 'result';
          const last = state.roundResults?.[state.roundResults.length-1];
          if(last) showResultScreen(last, state, false);
      }
      return;
  }

  if (state.phase === 'event') {
      if (_currentPhase !== 'event') {
          _currentPhase = 'event';
          showScreen('screen-event');
          document.getElementById('ev-q').textContent = state.mathEvent.q;
          const meAns = state.mathEvent.answers?.[myId]?.ans;
          renderMathChoices(state.mathEvent.choices, meAns);

          const me=state.players?.[myId];
          const amIHost = me?.isHost || isHost;

          if (amIHost) {
              if(!window.mathEventTimer) {
                  let tr = 15;
                  document.getElementById('ev-timer').textContent = tr;
                  clearInterval(evInterval);
                  evInterval = setInterval(()=>{
                     tr--; document.getElementById('ev-timer').textContent = tr;
                     if(tr<=0) clearInterval(evInterval);
                  },1000);

                  window.mathEventTimer = setTimeout(() => {
                      fbGet().then(st => {
                          if(st.phase === 'event' && !st.mathEvent.resolved) resolveMathEvent(st);
                      });
                  }, 15000);
              }
          }
      } else {
          const meAns = state.mathEvent.answers?.[myId]?.ans;
          if (meAns) renderMathChoices(state.mathEvent.choices, meAns);
      }

      const me=state.players?.[myId];
      const amIHost = me?.isHost || isHost;
      if (amIHost) {
          const ansCount = Object.keys(state.mathEvent.answers || {}).length;
          const psCount = orderedPlayers(state).length;
          if(ansCount === psCount && !state.mathEvent.resolved) resolveMathEvent(state);
      }
      return;
  }

  if (state.phase === 'event_result') {
       if (_currentPhase !== 'event_result') {
           _currentPhase = 'event_result';
           showScreen('screen-event-result');
           let html = '';
           const logs = state.mathEvent.resultLogs || [];
           if(logs.length === 0) html = '<div class="card" style="text-align:center;color:var(--muted)">ไม่มีใครตอบถูกเลย... 😢</div>';
           else {
               logs.forEach(l => {
                   const icon = l.rank===1?'🥇':l.rank===2?'🥈':'🥉';
                   html += `<div class="card" style="display:flex;justify-content:space-between;align-items:center;border-color:var(--gold);">
                     <div style="font-size:1.3rem;font-weight:700;">${icon} ${l.name}</div>
                     <div class="money" style="font-size:1.2rem;">+${fmt(l.reward)}</div>
                   </div>`;
               });
           }
           html += `<div style="text-align:center;margin-top:1.5rem;color:var(--muted);font-size:.85rem;">กำลังเข้าสู่ตาถัดไป...</div>`;
           document.getElementById('ev-res-content').innerHTML = html;
       }
       return;
  }

  if (state.phase === 'playing') {
      if (_currentPhase !== 'playing') {
          _currentPhase = 'playing';
          showScreen('screen-game');
      }
      const ps = orderedPlayers(state);
      const me = state.players?.[myId];
      const amIHost = me?.isHost || isHost;
      const allSub = ps.length > 0 && ps.every(p=>p.submitted);

      if (allSub && amIHost) {
          resolveRound(state);
          return;
      }

      if (me?.submitted) {
          renderWaiting(state, ps);
      } else {
          if(state.round !== _prevRound) {
              _prevRound = state.round;
              sel = {horse:null, horseAmt:0, houseBids:[], houseTemp:null};
          }
          renderActionUI(state, me, ps);
      }
  }
}

function updateHUD(state){
  const me=state?.players?.[myId];
  document.getElementById('hud-round').textContent=`ตา ${state?.round||1}/${TOTAL_ROUNDS}`;
  document.getElementById('my-money').textContent=fmt(me?.money??START_MONEY);
  document.getElementById('my-name-hud').textContent=myName;
  for(let i=1;i<=5;i++){
    const el=document.getElementById('pd'+i);if(!el)continue;
    const r=state?.round||1;
    el.className='pd'+(i<r?' done':i===r?' active':'');
  }
}

// ── MATH EVENT SYSTEM ──
function generateMathEvent() {
   const ops = ['+','-','*'];
   const op = ops[Math.floor(Math.random()*ops.length)];
   let a, b, ans;
   if(op==='+'){ a=Math.floor(Math.random()*50)+10; b=Math.floor(Math.random()*50)+10; ans=a+b; }
   else if(op==='-'){ a=Math.floor(Math.random()*50)+50; b=Math.floor(Math.random()*20)+10; ans=a-b; }
   else { a=Math.floor(Math.random()*11)+2; b=Math.floor(Math.random()*11)+2; ans=a*b; }
   
   let choices = [ans, ans+Math.floor(Math.random()*5)+1, ans-Math.floor(Math.random()*5)-1, ans+10];
   choices = [...new Set(choices)];
   while(choices.length < 4) {
       choices.push(ans + Math.floor(Math.random()*20)-10);
       choices = [...new Set(choices)];
   }
   choices.sort(() => Math.random() - 0.5);
   return { q: `${a} ${op} ${b} = ?`, choices, ans, answers: {} };
}

window.renderMathChoices = function(choices, meAns) {
    document.getElementById('ev-choices').innerHTML = choices.map(c => 
       `<div class="ev-btn ${meAns===c?'selected':''}" ${meAns?'':`onclick="submitMath(${c})"`} style="${meAns&&meAns!==c?'opacity:0.3':''}">${c}</div>`
    ).join('');
};

window.submitMath = async function(c) {
   const state = await fbGet();
   if(state.mathEvent?.answers?.[myId]) return;
   await fbUpd({ [`mathEvent/answers/${myId}`]: { ans: c, ts: Date.now() } });
   toast('✅ ส่งคำตอบแล้ว! รอลุ้นผล...');
};

async function resolveMathEvent(state) {
    if(window.mathEventTimer) { clearTimeout(window.mathEventTimer); window.mathEventTimer = null; }
    clearInterval(evInterval);
    
    await fbUpd({ 'mathEvent/resolved': true });
    let answers = Object.entries(state.mathEvent.answers || {}).map(([id, data]) => ({ id, ...data }));
    let correct = answers.filter(a => a.ans === state.mathEvent.ans);
    correct.sort((a,b) => a.ts - b.ts);
    
    let u = {};
    let logs = [];
    const rewards = [15000, 8000, 5000];
    
    correct.slice(0, 3).forEach((c, i) => {
        let p = state.players[c.id];
        u[`players/${c.id}/money`] = (p.money||0) + rewards[i];
        logs.push({ name: p.name, reward: rewards[i], rank: i+1 });
    });
    
    u['mathEvent/resultLogs'] = logs;
    u['phase'] = 'event_result';
    await fbUpd(u);
    
    setTimeout(async()=>{ await fbUpd({phase:'playing'}); }, 5000);
}

// ── ACTION UI ──
