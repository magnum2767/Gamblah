  await fb().update(rref(),u);
}

function goHome(){stopListen();showScreen('screen-home');}

// ── UTILS ──
function miniLB(ps){
  return[...ps].sort((a,b)=>b.money-a.money).slice(0,6).map((p,i)=>`
    <div class="lb-row">
      <div class="lb-rank r${i+1}">${i+1}</div>
      <div class="p-avatar c${p.colorIdx}" style="width:24px;height:24px;font-size:.7rem;border-radius:5px;">${p.avatar}</div>
      <div class="lb-name">${p.name}${p.id===myId?' <span style="color:var(--gold);font-size:.6rem">(คุณ)</span>':''}</div>
      <div class="lb-money">${fmt(p.money)}</div>
    </div>`).join('');
}

function spawnConfetti(){
  const cols=['#f5c518','#00c97a','#ff4560','#3b82f6','#a855f7','#fff'];
  for(let i=0;i<70;i++){
    const el=document.createElement('div');el.className='confetti-piece';
    el.style.cssText=`left:${Math.random()*100}%;background:${cols[Math.floor(Math.random()*cols.length)]};
      animation-duration:${1.5+Math.random()*2}s;animation-delay:${Math.random()*1.2}s;
      width:${6+Math.random()*8}px;height:${6+Math.random()*8}px;
      border-radius:${Math.random()>.5?'50%':'2px'};`;
    document.body.appendChild(el);setTimeout(()=>el.remove(),4500);
  }
}

document.addEventListener('DOMContentLoaded',()=>generateRoomCode());
