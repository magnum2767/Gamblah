// ── RESOLVE ROUND (HOST) ──
async function resolveRound(state){
  if(_resolving) return;
  _resolving = true;
  try {
    const ps=orderedPlayers(state);
    const horses=[...Array(12)].map((_,i)=>i+1);
    for(let i=11;i>0;i--){const j=Math.floor(Math.random()*(i+1));[horses[i],horses[j]]=[horses[j],horses[i]];}
    const horseRank={};horses.forEach((h,i)=>horseRank[h]=i+1);

    const delta={};ps.forEach(p=>delta[p.id]=0);
    const horseRes=[],houseRes=[];

    // 1. Horses
    ps.forEach(p=>{
      if(p.horse&&p.horseAmt>0){
        const rank=horseRank[p.horse];
        const pct=HORSE_REWARD_PCT[rank-1]/100;
        const payout=Math.floor(p.horseAmt*pct);
        delta[p.id]+=payout-p.horseAmt;
        horseRes.push({playerId:p.id,playerName:p.name,avatar:p.avatar,colorIdx:p.colorIdx,
          horse:p.horse,rank,amount:p.horseAmt,pct:HORSE_REWARD_PCT[rank-1],payout,net:payout-p.horseAmt});
      }
    });

    const newHouses={...(state.houses||{})};

    // 2. Houses and Emperor
    if(state.round<TOTAL_ROUNDS){
      const bidsMap={};
      ps.forEach(p=>{
        if(p.houseBids&&p.houseBids.length>0){
          p.houseBids.forEach(b => {
            if(!bidsMap[b.slot]) bidsMap[b.slot]=[];
            bidsMap[b.slot].push({playerId:p.id,playerName:p.name,avatar:p.avatar,colorIdx:p.colorIdx,amount:b.amount});
          });
        }
      });
      
      let empWinner = null;
      
      Object.entries(bidsMap).forEach(([slot,bids])=>{
        bids.sort((a,b)=>b.amount-a.amount);
        const w=bids[0],losers=bids.slice(1);
        const type=slot==='จักรพรรดิ'?'EMP':slot[0],roi=HOUSES[type].roi;
        
        if (slot === 'จักรพรรดิ') {
             delta[w.playerId] -= w.amount;
             newHouses[slot] = {owner:w.playerId,ownerName:w.playerName,round:state.round};
             losers.forEach(l=>delta[l.playerId]-=l.amount);
             houseRes.push({slot,roi:0,winner:w,losers,payout:0,winNet:-w.amount});
             empWinner = w;
        } else {
             const payout=Math.floor(w.amount*roi);
             delta[w.playerId]+=payout-w.amount;
             newHouses[slot]={owner:w.playerId,ownerName:w.playerName,round:state.round};
             losers.forEach(l=>delta[l.playerId]-=l.amount);
             houseRes.push({slot,roi:roi*100,winner:w,losers,payout,winNet:payout-w.amount});
        }
      });

      // Grant random 3 houses to EMP winner
      if(empWinner) {
         const myOwned = Object.entries(newHouses).filter(([k,v]) => v.owner === empWinner.playerId).map(e=>e[0]);
         const allSlots = [...HOUSES.A.slots, ...HOUSES.B.slots, ...HOUSES.C.slots];
         const validSlots = allSlots.filter(s => !myOwned.includes(s));
         validSlots.sort(() => Math.random() - 0.5);
         const wonSlots = validSlots.slice(0, 3);
         wonSlots.forEach(s => {
            newHouses[s] = { owner: empWinner.playerId, ownerName: empWinner.playerName, round: state.round };
         });
         const empResIdx = houseRes.findIndex(r => r.slot === 'จักรพรรดิ');
         if(empResIdx >= 0) houseRes[empResIdx].wonSlots = wonSlots;
      }
    }

    // Apply money
    const updPs={};
    ps.forEach(p=>{
      updPs[p.id]={...state.players[p.id],
        money:(p.money||0)+(delta[p.id]||0),
        horse:null,horseAmt:0,houseBids:null,submitted:false};
    });

    const snaps=ps.map(p=>({id:p.id,name:p.name,avatar:p.avatar,colorIdx:p.colorIdx,
      money:(p.money||0)+(delta[p.id]||0)}));
    const roundResult={round:state.round,horses,horseRank,horseRes,houseRes,snaps};
    const prevResults=[...(state.roundResults||[]),roundResult];

    const isEnd=state.round>=TOTAL_ROUNDS;
    const u={};
    if(isEnd){
      const hc={}; let empOwner=null;
      Object.entries(newHouses).forEach(([s,h])=>{
        if(s==='จักรพรรดิ') empOwner=h.owner;
        else hc[h.owner]=(hc[h.owner]||0)+1;
      });
      
      Object.entries(hc).forEach(([pid,cnt])=>{
        if(updPs[pid])updPs[pid].money+=cnt*HOUSE_END_BONUS;
        const s=snaps.find(p=>p.id===pid);if(s)s.money+=cnt*HOUSE_END_BONUS;
      });
      if(empOwner){
        if(updPs[empOwner]) updPs[empOwner].money+=30000;
        const s=snaps.find(p=>p.id===empOwner);if(s)s.money+=30000;
      }
      u.phase='ended';
    } else {
      u.phase='result';
    }
    
    u.round=state.round+(isEnd?0:1);
    u.houses=newHouses;
    u.roundResults=prevResults;
    Object.entries(updPs).forEach(([pid,p])=>u[`players/${pid}`]=p);
    
    await fb().update(rref(),u);

  } finally {
    _resolving = false;
  }
}

